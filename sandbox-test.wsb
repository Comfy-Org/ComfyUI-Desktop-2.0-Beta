<Configuration>
    <VGpu>Disable</VGpu>
    <Networking>Default</Networking>
    <MappedFolders>
        <MappedFolder>
            <HostFolder>C:\Users\Kosinkadink\comfy-vibe-station\pr-tracker\stations\station2\ComfyUI-Launcher\dist</HostFolder>
            <SandboxFolder>C:\installers</SandboxFolder>
            <ReadOnly>true</ReadOnly>
        </MappedFolder>
    </MappedFolders>
    <LogonCommand>
        <Command>powershell.exe -ExecutionPolicy Bypass -NoExit -Command "Copy-Item C:\installers\*.exe $env:USERPROFILE\Desktop\ -Force; Set-Location $env:USERPROFILE\Desktop; Write-Host '=== PR #460 silent-update test (assisted installer) ===' -ForegroundColor Cyan; Write-Host 'Installer copied to Desktop:' -ForegroundColor Green; Get-ChildItem *.exe | Format-Table Name, @{N='SizeMB';E={[math]::Round($_.Length/1MB,1)}}; Write-Host ''; Write-Host 'TEST 1 (fresh install - assisted wizard with directory picker should appear):' -ForegroundColor Yellow; Write-Host '  .\ComfyUI-Desktop-2.0-0.5.0-win-x64.exe' -ForegroundColor White; Write-Host ''; Write-Host 'TEST 2 (silent update via /S - NO UI should appear):' -ForegroundColor Yellow; Write-Host '  Start-Process .\ComfyUI-Desktop-2.0-0.5.0-win-x64.exe -ArgumentList ''/S'' -Wait' -ForegroundColor White; Write-Host ''"</Command>
    </LogonCommand>
</Configuration>
